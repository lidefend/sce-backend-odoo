FROM odoo:17.0@sha256:f88f646a0f5fc0b225995ee28953d9ce7367cc731b1756765114691fb97d18e5

USER root

COPY requirements-odoo.txt /tmp/requirements-odoo.txt
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get dist-upgrade -y \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends gettext-base nginx \
    && apt-get purge -y nodejs npm node-less libnode-dev libnode72 \
    && apt-get autoremove -y --purge \
    && rm -rf /usr/local/bin/rtlcss /usr/local/lib/node_modules/rtlcss \
    && rm -f /usr/share/java/libintl-*.jar \
    && ! command -v node \
    && ! command -v lessc \
    && ! command -v rtlcss \
    && ! find /usr/share/java -type f -name '*.jar' -print -quit | grep -q . \
    && ! dpkg-query -W -f='${binary:Package}\t${db:Status-Status}\n' 'node-*' 'libnode*' 2>/dev/null \
        | awk '$2 == "installed" { found=1 } END { exit(found ? 0 : 1) }' \
    && pip3 install --no-cache-dir -r /tmp/requirements-odoo.txt \
    && rm -rf /var/lib/apt/lists/* /tmp/requirements-odoo.txt

RUN mkdir -p /mnt/product-addons /mnt/customer-addons /mnt/test-addons /mnt/source-addons \
    && ln -s /mnt/product-addons /mnt/extra-addons
COPY addons/sc_norm_engine /mnt/product-addons/sc_norm_engine
COPY addons/smart_core /mnt/product-addons/smart_core
COPY addons/smart_scene /mnt/product-addons/smart_scene
COPY addons/smart_license_core /mnt/product-addons/smart_license_core
COPY addons/smart_construction_bootstrap /mnt/product-addons/smart_construction_bootstrap
COPY addons/smart_construction_core /mnt/product-addons/smart_construction_core
COPY addons/smart_construction_portal /mnt/product-addons/smart_construction_portal
COPY addons/smart_construction_scene /mnt/product-addons/smart_construction_scene
COPY addons/smart_construction_bundle /mnt/product-addons/smart_construction_bundle
COPY addons/smart_construction_seed /mnt/product-addons/smart_construction_seed
COPY addons/smart_owner_core /mnt/product-addons/smart_owner_core
COPY addons/smart_owner_bundle /mnt/product-addons/smart_owner_bundle
COPY addons_external/oca_server_ux /mnt/addons_external/oca_server_ux
COPY config/odoo.conf.template /etc/odoo/odoo.conf.template
COPY config/nginx/conf.d/production-candidate.conf /etc/nginx/templates/default.conf.template
COPY scripts/render_odoo_conf.py /usr/local/bin/render_odoo_conf.py
COPY scripts/render_nginx_conf.sh /usr/local/bin/render_nginx_conf.sh
COPY scripts/odoo-entrypoint.sh /usr/local/bin/odoo-entrypoint.sh
COPY frontend/apps/web/dist-production-candidate /usr/share/nginx/html
COPY VERSION /opt/sce-product/VERSION
COPY release/product-release.yaml /opt/sce-product/product-release.yaml

RUN chmod 0755 /usr/local/bin/odoo-entrypoint.sh /usr/local/bin/render_odoo_conf.py /usr/local/bin/render_nginx_conf.sh \
    && rm -f /etc/nginx/sites-enabled/default \
    && find /mnt/product-addons /mnt/customer-addons /mnt/test-addons /mnt/source-addons /mnt/addons_external -type d -exec chmod 0755 {} + \
    && find /mnt/product-addons /mnt/customer-addons /mnt/test-addons /mnt/source-addons /mnt/addons_external -type f -exec chmod 0644 {} + \
    && chown -R root:root /mnt/product-addons /mnt/customer-addons /mnt/test-addons /mnt/source-addons /mnt/addons_external /usr/share/nginx/html

ARG SOURCE_SHA
ARG PRODUCT_VERSION
ARG FRONTEND_BUILD_SHA256
ARG BUILD_TIME
ARG ODOO_VERSION=17.0
ARG PYTHON_VERSION
ARG NODE_VERSION
ARG PNPM_VERSION

ENV SC_PRODUCT_VERSION="${PRODUCT_VERSION}" \
    SC_SOURCE_REVISION="${SOURCE_SHA}"

LABEL org.opencontainers.image.revision="${SOURCE_SHA}" \
      org.opencontainers.image.created="${BUILD_TIME}" \
      org.opencontainers.image.title="sce-product" \
      org.opencontainers.image.version="${PRODUCT_VERSION}" \
      com.sce.frontend.sha256="${FRONTEND_BUILD_SHA256}" \
      com.sce.odoo.version="${ODOO_VERSION}" \
      com.sce.python.version="${PYTHON_VERSION}" \
      com.sce.node.version="${NODE_VERSION}" \
      com.sce.pnpm.version="${PNPM_VERSION}" \
      com.sce.node.runtime="absent" \
      com.sce.rtl.boundary="unsupported-ltr-only"

USER odoo
ENTRYPOINT ["/usr/local/bin/odoo-entrypoint.sh"]
