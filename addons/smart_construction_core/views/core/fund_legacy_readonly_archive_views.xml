<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sc_fuel_card_archive_search" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.fuel.card.archive.search</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <search string="油卡登记历史归档">
                <field name="name"/>
                <field name="project_id"/>
                <field name="operation_date"/>
                <field name="fund_account_id"/>
                <field name="creator_name"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按日期" name="group_operation_date" context="{'group_by': 'operation_date'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_fuel_card_archive_tree" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.fuel.card.archive.tree</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <tree string="油卡登记历史归档" create="false" edit="false" delete="false" duplicate="false" default_order="operation_date desc,id desc">
                <field name="name"/>
                <field name="operation_date"/>
                <field name="project_id"/>
                <field name="fund_account_id"/>
                <field name="amount" sum="金额合计"/>
                <field name="operation_reason"/>
                <field name="legacy_document_state"/>
                <field name="creator_name"/>
                <field name="created_time"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_fuel_card_archive_form" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.fuel.card.archive.form</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <form string="油卡登记历史归档" create="false" edit="false" delete="false" duplicate="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="operation_date" readonly="1"/>
                            <field name="fund_account_id" readonly="1"/>
                            <field name="amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="legacy_document_state" readonly="1"/>
                            <field name="creator_name" readonly="1"/>
                            <field name="created_time" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="operation_reason" readonly="1"/>
                        <field name="note" readonly="1"/>
                        <field name="attachment_ids" widget="many2many_binary" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_fuel_recharge_archive_search" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.fuel.recharge.archive.search</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <search string="充值登记历史归档">
                <field name="name"/>
                <field name="project_id"/>
                <field name="operation_date"/>
                <field name="fund_account_id"/>
                <field name="creator_name"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按日期" name="group_operation_date" context="{'group_by': 'operation_date'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_fuel_recharge_archive_tree" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.fuel.recharge.archive.tree</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <tree string="充值登记历史归档" create="false" edit="false" delete="false" duplicate="false" default_order="operation_date desc,id desc">
                <field name="name"/>
                <field name="operation_date"/>
                <field name="project_id"/>
                <field name="fund_account_id"/>
                <field name="amount" sum="金额合计"/>
                <field name="operation_reason"/>
                <field name="legacy_document_state"/>
                <field name="creator_name"/>
                <field name="created_time"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_fuel_recharge_archive_form" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.fuel.recharge.archive.form</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <form string="充值登记历史归档" create="false" edit="false" delete="false" duplicate="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="operation_date" readonly="1"/>
                            <field name="fund_account_id" readonly="1"/>
                            <field name="amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="legacy_document_state" readonly="1"/>
                            <field name="creator_name" readonly="1"/>
                            <field name="created_time" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="operation_reason" readonly="1"/>
                        <field name="note" readonly="1"/>
                        <field name="attachment_ids" widget="many2many_binary" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_fuel_card_registration_formal" model="ir.actions.act_window">
        <field name="name">油卡登记</field>
        <field name="res_model">sc.fund.account.operation</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_sc_fuel_card_archive_tree"/>
        <field name="views" eval="[(ref('view_sc_fuel_card_archive_tree'), 'tree'), (ref('view_sc_fuel_card_archive_form'), 'form')]"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sc_fuel_card_archive_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sc_fuel_card_archive_form')})
        ]"/>
        <field name="search_view_id" ref="view_sc_fuel_card_archive_search"/>
        <field name="domain">[('legacy_source_model', '=', 'online_old_legacy_direct:direct_acceptance'), ('legacy_source_table', '=', 'direct_acceptance:油卡登记')]</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False, 'duplicate': False}</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_finance_read')])]"/>
    </record>

    <record id="action_sc_fuel_card_recharge_formal" model="ir.actions.act_window">
        <field name="name">充值登记</field>
        <field name="res_model">sc.fund.account.operation</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_sc_fuel_recharge_archive_tree"/>
        <field name="views" eval="[(ref('view_sc_fuel_recharge_archive_tree'), 'tree'), (ref('view_sc_fuel_recharge_archive_form'), 'form')]"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sc_fuel_recharge_archive_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sc_fuel_recharge_archive_form')})
        ]"/>
        <field name="search_view_id" ref="view_sc_fuel_recharge_archive_search"/>
        <field name="domain">[('legacy_source_model', '=', 'online_old_legacy_direct:direct_acceptance'), ('legacy_source_table', '=', 'direct_acceptance:充值登记')]</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False, 'duplicate': False}</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_finance_read')])]"/>
    </record>

    <menuitem id="menu_sc_fuel_card_archive_group"
              name="油卡管理"
              parent="smart_construction_core.menu_sc_finance_center"
              sequence="48"
              groups="smart_construction_core.group_sc_cap_finance_read"/>
    <menuitem id="menu_sc_legacy_fuel_card_fact_acceptance"
              name="油卡登记"
              parent="smart_construction_core.menu_sc_fuel_card_archive_group"
              action="smart_construction_core.action_sc_fuel_card_registration_formal"
              sequence="10"
              groups="smart_construction_core.group_sc_cap_finance_read"/>
    <menuitem id="menu_sc_legacy_fuel_card_recharge_fact_acceptance"
              name="充值登记"
              parent="smart_construction_core.menu_sc_fuel_card_archive_group"
              action="smart_construction_core.action_sc_fuel_card_recharge_formal"
              sequence="20"
              groups="smart_construction_core.group_sc_cap_finance_read"/>
</odoo>
