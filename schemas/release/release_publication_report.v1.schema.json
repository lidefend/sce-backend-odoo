{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sce.example/schemas/release/release_publication_report.v1.schema.json",
  "title": "Resumable release publication attempt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "publication_attempt_id",
    "created_at",
    "updated_at",
    "finished_at",
    "previous_state",
    "state",
    "PUBLICATION_COMPLETE",
    "identity",
    "plan",
    "external",
    "failure",
    "evidence",
    "publication_manifest",
    "history"
  ],
  "properties": {
    "schema_version": {"const": "release_publication_report.v1"},
    "publication_attempt_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z-[0-9a-f]{32}$"
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": ["string", "null"], "format": "date-time"},
    "previous_state": {"type": ["string", "null"]},
    "state": {
      "enum": [
        "PLANNED",
        "PREFLIGHT_PASSED",
        "REGISTRY_PUSH_IN_PROGRESS",
        "REGISTRY_PUSHED",
        "TAG_CREATE_IN_PROGRESS",
        "TAG_CREATED",
        "RELEASE_CREATE_IN_PROGRESS",
        "RELEASE_PUBLISHED",
        "PUBLICATION_COMPLETE",
        "FAILED_PREFLIGHT",
        "FAILED_REGISTRY_PUSH",
        "FAILED_TAG_CREATE",
        "FAILED_RELEASE_CREATE",
        "REJECT_IDENTITY_MISMATCH",
        "REJECT_ALREADY_PUBLISHED",
        "REJECT_CONCURRENT_PUBLICATION"
      ]
    },
    "PUBLICATION_COMPLETE": {"type": "boolean"},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "candidate_attempt_id",
        "source_sha"
      ],
      "properties": {
        "version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"},
        "candidate_attempt_id": {
          "pattern": "^[0-9]{8}T[0-9]{6}Z-[0-9a-f]{32}$"
        },
        "source_sha": {"pattern": "^[0-9a-f]{40}$"},
        "source_tree": {"pattern": "^[0-9a-f]{40}$"},
        "candidate_report_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "candidate_manifest_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "candidate_archive_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "candidate_sbom_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "candidate_image_content_id": {"pattern": "^sha256:[0-9a-f]{64}$"},
        "candidate_tool_contract_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "publication_workflow_sha256": {"pattern": "^[0-9a-f]{64}$"}
      }
    },
    "plan": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"const": "publication-plan.json"},
        "sha256": {"pattern": "^[0-9a-f]{64}$"}
      }
    },
    "external": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry", "tags", "release"],
      "properties": {
        "registry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["digest", "tags"],
          "properties": {
            "digest": {
              "type": ["string", "null"],
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "tags": {"type": "array", "items": {"type": "string"}}
          }
        },
        "tags": {
          "type": "object",
          "additionalProperties": false,
          "required": ["github", "gitee"],
          "properties": {
            "github": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
            "gitee": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"}
          }
        },
        "release": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag", "url"],
          "properties": {
            "tag": {"type": ["string", "null"]},
            "url": {"type": ["string", "null"]}
          }
        }
      }
    },
    "failure": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["stage", "message"],
      "properties": {
        "stage": {"type": "string"},
        "message": {"type": "string"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["log"],
      "properties": {
        "log": {"const": "logs/publication.log"}
      }
    },
    "publication_manifest": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"const": "publication-manifest.json"},
        "sha256": {"pattern": "^[0-9a-f]{64}$"}
      }
    },
    "history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state", "previous_state", "recorded_at"],
        "properties": {
          "state": {"type": "string"},
          "previous_state": {"type": ["string", "null"]},
          "recorded_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"plan": {"type": "object"}}},
      "then": {
        "properties": {
          "identity": {
            "required": [
              "source_tree",
              "candidate_report_sha256",
              "candidate_manifest_sha256",
              "candidate_archive_sha256",
              "candidate_sbom_sha256",
              "candidate_image_content_id",
              "candidate_tool_contract_sha256",
              "publication_workflow_sha256"
            ]
          }
        }
      }
    },
    {
      "if": {"properties": {"state": {"const": "PUBLICATION_COMPLETE"}}},
      "then": {
        "properties": {
          "PUBLICATION_COMPLETE": {"const": true},
          "failure": {"type": "null"},
          "publication_manifest": {"type": "object"}
        }
      }
    }
  ]
}
